              'x-api-token': ApiConfig.apiToken,
            },
            body: jsonEncode({
              'dipendente_id': dipendenteId,
              'tipo': tipo,
              'data_inizio': dataInizio,
              'data_fine': dataFine,
              'note': note,
              'stato': 'richiesta',
            }),
